<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  ╔══════════════════════════════════════════════════════════════════════════╗
  ║  Checkstyle Configuration — Lexicon Compile Service                     ║
  ║  com.db.macs3.ecomms.spectre                                            ║
  ║                                                                          ║
  ║  Compatible with: checkstyle 10.12.5 / maven-checkstyle-plugin 3.3.1   ║
  ║                                                                          ║
  ║  BREAKING CHANGE from Checkstyle 8.42+:                                 ║
  ║   JavadocMethod.scope   → JavadocMethod.accessModifiers                 ║
  ║   JavadocVariable.scope → JavadocVariable.accessModifiers               ║
  ║   JavadocType.scope is still valid in 10.x                              ║
  ║                                                                          ║
  ║  Rules summary:                                                          ║
  ║   • 120-character line limit                                             ║
  ║   • 4-space indentation (no tabs)                                        ║
  ║   • Javadoc on public classes and public methods                        ║
  ║   • No wildcard imports                                                  ║
  ║   • No javax.servlet.* (use jakarta.*)                                  ║
  ║   • SLF4J enforcement — no System.out or printStackTrace()             ║
  ║   • ConstantName allows "log" for the SLF4J Logger field               ║
  ╚══════════════════════════════════════════════════════════════════════════╝
-->
<module name="Checker">

    <!-- ── Checker-level properties ────────────────────────────────────────── -->
    <property name="charset"        value="UTF-8"/>
    <property name="severity"       value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- Load suppressions from suppressions.xml in the same directory -->
    <module name="SuppressionFilter">
        <property name="file"     value="${config_loc}/suppressions.xml"/>
        <property name="optional" value="false"/>
    </module>

    <!-- ── File-level checks ────────────────────────────────────────────────── -->

    <!-- Tabs are not allowed — use 4 spaces throughout -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Every Java file must end with a newline character -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>

    <!-- Warn when a file exceeds 1000 lines (prevents monolithic classes) -->
    <module name="FileLength">
        <property name="max"      value="1000"/>
        <property name="severity" value="warning"/>
    </module>

    <!-- ── TreeWalker — per-token AST checks ────────────────────────────────── -->
    <module name="TreeWalker">

        <!-- ── Javadoc ──────────────────────────────────────────────────────── -->

        <!--
          JavadocMethod — checks FORMAT of existing Javadoc on methods.
          NOTE (Checkstyle 8.42+): 'scope' was REMOVED. Use 'accessModifiers'.
          accessModifiers="public" → only check public methods.
          Suppressions.xml relaxes this for getters, records, test classes, etc.
        -->
        <module name="JavadocMethod">
            <property name="accessModifiers"      value="public"/>
            <property name="allowMissingParamTags" value="true"/>
            <property name="allowMissingReturnTag" value="true"/>
        </module>

        <!--
          JavadocType — checks Javadoc on type declarations.
          NOTE: JavadocType still uses 'scope' in Checkstyle 10.x (not renamed).
          scope="public" → only check public types.
        -->
        <module name="JavadocType">
            <property name="scope"                value="public"/>
            <property name="allowMissingParamTags" value="true"/>
        </module>

        <!--
          JavadocVariable — checks Javadoc on fields/variables.
          NOTE (Checkstyle 8.42+): 'scope' was REMOVED. Use 'accessModifiers'.
          accessModifiers="public" → only check public fields.
          Suppressions.xml relaxes this for model/config classes.
        -->
        <module name="JavadocVariable">
            <property name="accessModifiers" value="public"/>
        </module>

        <!-- Javadoc content: first sentence must end with a period -->
        <module name="JavadocStyle">
            <property name="checkFirstSentence" value="true"/>
        </module>

        <!-- ── Naming conventions ───────────────────────────────────────────── -->

        <!--
          Constants: UPPER_SNAKE_CASE
          Exception: "log" and "logger" are allowed for the SLF4J Logger field:
            private static final Logger log = LoggerFactory.getLogger(X.class);
        -->
        <module name="ConstantName">
            <property name="format" value="^log$|^logger$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- Local variables: lowerCamelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Instance fields: lowerCamelCase -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Methods: lowerCamelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Packages: all-lowercase dot-separated -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- Parameters: lowerCamelCase -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Static non-final fields: lowerCamelCase -->
        <module name="StaticVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Types (class/interface/enum/annotation): UpperCamelCase -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Catch parameters: lowerCamelCase -->
        <module name="CatchParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- ── Imports ──────────────────────────────────────────────────────── -->

        <!-- No wildcard imports: import java.util.* is not allowed -->
        <module name="AvoidStarImport"/>

        <!--
          No javax.servlet.*, javax.validation.*, javax.annotation.*
          The project uses jakarta.* (Spring Boot 4 / Jakarta EE 10).
        -->
        <module name="IllegalImport">
            <property name="illegalPkgs"
                      value="javax.servlet, javax.validation, javax.annotation"/>
        </module>

        <!-- Remove redundant imports (already imported or in java.lang) -->
        <module name="RedundantImport"/>

        <!-- Remove unused imports -->
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>

        <!-- ── Line length ───────────────────────────────────────────────────── -->

        <!--
          Maximum 120 characters per line.
          Exemptions: package/import lines, and http(s):// URLs in Javadoc.
        -->
        <module name="LineLength">
            <property name="max"           value="120"/>
            <property name="ignorePattern"
                      value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        </module>

        <!-- ── Whitespace ───────────────────────────────────────────────────── -->

        <!-- No space inside angle brackets: Map<String, List<String>> -->
        <module name="GenericWhitespace"/>

        <!-- No space before method parameter parenthesis: foo() not foo () -->
        <module name="MethodParamPad"/>

        <!-- No whitespace before semicolons and commas -->
        <module name="NoWhitespaceBefore"/>

        <!-- No whitespace after unary operators and certain others -->
        <module name="NoWhitespaceAfter">
            <property name="tokens"
                      value="BNOT, DEC, DOT, INC, LNOT, UNARY_MINUS,
                             UNARY_PLUS, ARRAY_DECLARATOR"/>
        </module>

        <!-- No space inside parentheses: foo(x) not foo( x ) -->
        <module name="ParenPad"/>

        <!-- Space after comma, semicolon in for-loops, and certain keywords -->
        <module name="WhitespaceAfter">
            <property name="tokens"
                      value="COMMA, SEMI, TYPECAST, LITERAL_IF, LITERAL_ELSE,
                             LITERAL_WHILE, LITERAL_DO, LITERAL_FOR, DO_WHILE"/>
        </module>

        <!-- Space around binary operators and assignment -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors"  value="true"/>
            <property name="allowEmptyMethods"       value="true"/>
            <property name="allowEmptyTypes"         value="true"/>
            <property name="allowEmptyLoops"         value="true"/>
            <property name="allowEmptyLambdas"       value="true"/>
            <property name="ignoreEnhancedForColon"  value="true"/>
        </module>

        <!-- ── Indentation ──────────────────────────────────────────────────── -->

        <module name="Indentation">
            <property name="basicOffset"             value="4"/>
            <property name="braceAdjustment"         value="0"/>
            <property name="caseIndent"              value="4"/>
            <property name="throwsIndent"            value="8"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent"         value="4"/>
        </module>

        <!-- ── Blocks and braces ────────────────────────────────────────────── -->

        <!-- Empty blocks must contain at least a comment explaining why -->
        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
            <property name="tokens" value="LITERAL_WHILE, LITERAL_TRY,
                                           LITERAL_FINALLY, LITERAL_DO,
                                           LITERAL_IF, LITERAL_ELSE,
                                           LITERAL_FOR, INSTANCE_INIT,
                                           STATIC_INIT, LITERAL_SWITCH,
                                           LITERAL_SYNCHRONIZED"/>
        </module>

        <!-- Opening brace on same line as the declaration -->
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>

        <!-- All control structures must use braces -->
        <module name="NeedBraces">
            <property name="tokens"
                      value="LITERAL_DO, LITERAL_ELSE, LITERAL_FOR,
                             LITERAL_IF, LITERAL_WHILE"/>
        </module>

        <!-- Closing brace: else/catch/finally on same line -->
        <module name="RightCurly">
            <property name="option" value="same"/>
            <property name="tokens"
                      value="LITERAL_TRY, LITERAL_CATCH, LITERAL_FINALLY,
                             LITERAL_IF, LITERAL_ELSE, LITERAL_DO"/>
        </module>

        <!-- ── Coding rules ──────────────────────────────────────────────────── -->

        <!-- No stray semicolons (empty statements) -->
        <module name="EmptyStatement"/>

        <!-- equals() and hashCode() must be overridden together -->
        <module name="EqualsHashCode"/>

        <!-- No fall-through in switch cases without a comment -->
        <module name="FallThrough"/>

        <!-- switch statement must have a default case -->
        <module name="MissingSwitchDefault"/>

        <!-- One variable declaration per statement -->
        <module name="MultipleVariableDeclarations"/>

        <!-- No finalizer methods (finalize()) -->
        <module name="NoFinalizer"/>

        <!-- One statement per line -->
        <module name="OneStatementPerLine"/>

        <!-- Overloaded methods must be grouped together -->
        <module name="OverloadMethodsDeclarationOrder"/>

        <!-- Simplify: if (b == true) → if (b) -->
        <module name="SimplifyBooleanExpression"/>

        <!-- Simplify: if (x) return true; else return false; → return x; -->
        <module name="SimplifyBooleanReturn"/>

        <!-- Use .equals() not == for String comparison -->
        <module name="StringLiteralEquality"/>

        <!-- ── Logging enforcement ───────────────────────────────────────────── -->

        <!--
          ERROR: No System.out.println — use SLF4J: log.info("...")
          (Test classes are exempted in suppressions.xml)
        -->
        <module name="RegexpSinglelineJava">
            <property name="format"
                      value="System\.out\.println"/>
            <property name="message"
                      value="[LOGGING] Use SLF4J logger instead of System.out.println"/>
            <property name="severity" value="error"/>
        </module>

        <!--
          ERROR: No e.printStackTrace() — use SLF4J: log.error("msg", e)
        -->
        <module name="RegexpSinglelineJava">
            <property name="format"
                      value="e\.printStackTrace\(\)"/>
            <property name="message"
                      value="[LOGGING] Use log.error(msg, e) instead of e.printStackTrace()"/>
            <property name="severity" value="error"/>
        </module>

        <!--
          ERROR: No System.err.println — not visible in Cloud Run structured logs
        -->
        <module name="RegexpSinglelineJava">
            <property name="format"
                      value="System\.err\.println"/>
            <property name="message"
                      value="[LOGGING] Use SLF4J logger instead of System.err.println"/>
            <property name="severity" value="error"/>
        </module>

        <!-- ── Class design ─────────────────────────────────────────────────── -->

        <!-- Utility classes (all-static methods) must have a private constructor -->
        <module name="HideUtilityClassConstructor"/>

        <!-- Interfaces must define methods, not only constants -->
        <module name="InterfaceIsType"/>

        <!--
          Visibility modifier:
            - Instance fields must be private
            - Protected fields allowed (test fixtures, abstract classes)
            - Public final / public immutable fields allowed (records, constants)
          Relaxed in suppressions.xml for Spring @ConfigurationProperties beans.
        -->
        <module name="VisibilityModifier">
            <property name="packageAllowed"             value="false"/>
            <property name="protectedAllowed"           value="true"/>
            <property name="allowPublicFinalFields"     value="true"/>
            <property name="allowPublicImmutableFields" value="true"/>
        </module>

        <!-- ── Complexity limits (warnings, not errors) ──────────────────────── -->

        <!--
          Cyclomatic complexity: warn above 15.
          TermSyntaxTranslator.parseExpression() exceeds this by design
          and is suppressed in suppressions.xml.
        -->
        <module name="CyclomaticComplexity">
            <property name="max"      value="15"/>
            <property name="severity" value="warning"/>
        </module>

        <!-- Method length: warn above 80 lines (excluding blanks and comments) -->
        <module name="MethodLength">
            <property name="max"        value="80"/>
            <property name="countEmpty" value="false"/>
            <property name="severity"   value="warning"/>
        </module>

        <!-- Parameter count: warn above 8 parameters per method -->
        <module name="ParameterNumber">
            <property name="max"      value="8"/>
            <property name="severity" value="warning"/>
        </module>

        <!-- ── Annotations ──────────────────────────────────────────────────── -->

        <!-- @Override must always be used when overriding a method -->
        <module name="MissingOverride"/>

        <!-- ── Miscellaneous ────────────────────────────────────────────────── -->

        <!-- Array types: use String[] args not String args[] -->
        <module name="ArrayTypeStyle"/>

        <!-- Long literal suffix must be uppercase L (not l which looks like 1) -->
        <module name="UpperEll"/>

    </module>

</module>
